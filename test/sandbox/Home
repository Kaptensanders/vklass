	//requestAnimationFrame polyfill
	//https://www.paulirish.com/2011/requestanimationframe-for-smart-animating/
	(function () {
		var lastTime = 0;
		var vendors = ['webkit', 'moz'];
		for (var x = 0; x < vendors.length && !window.requestAnimationFrame; ++x) {
			window.requestAnimationFrame = window[vendors[x] + 'RequestAnimationFrame'];
			window.cancelAnimationFrame =
				window[vendors[x] + 'CancelAnimationFrame'] || window[vendors[x] + 'CancelRequestAnimationFrame'];
		}

		if (!window.requestAnimationFrame)
			window.requestAnimationFrame = function (callback, element) {
				var currTime = new Date().getTime();
				var timeToCall = Math.max(0, 16 - (currTime - lastTime));
				var id = window.setTimeout(function () { callback(currTime + timeToCall); },
					timeToCall);
				lastTime = currTime + timeToCall;
				return id;
			};

		if (!window.cancelAnimationFrame)
			window.cancelAnimationFrame = function (id) {
				clearTimeout(id);
			};
	}());
</script>



<script>
	function visualizeScreenReader() {
		if ($('body').hasClass('vk-visualize-sr')) {
			console.log('Screen reader already visualized');
			return;
		}

		$('body').addClass('vk-visualize-sr');

		$('.material-icons').css('opacity', '0.5');

		$('button.mdc-radio__native-control').css('opacity', '1');

		$('[aria-hidden="true"]:not([role="separator"])').each(function () {
			if ($(this).closest('.material-icons').length === 0) {
				$(this).css({ display: 'none', opacity: '0' });

				if ($(this).is('.mdc-tab') && $(this).closest('.mdc-tab-bar--vk-first-tab-empty').length) {
					$(this).css({ display: '', visibility: 'invisible' });
				}
			}
		});

		$('.sr-only, .sr-only-phone').each(function () {
			var srClass = $(this).hasClass('sr-only-phone') ? 'sr-only-phone' : 'sr-only';
			$(this).attr('data-vk-sr-class', srClass);

			if ($(this).parent().is('.material-icons')) {
				$(this).parent().attr('data-vk-remove-title', 'true').attr('title', $(this).text()).css('background-color', 'pink');
				if ($(this).prev().is('[aria-hidden="true"][title]')) {
					$(this).prev().attr('data-vk-original-title', $(this).prev().attr('title')).removeAttr('title');
				}
			} else if ($(this).prev().is('.material-icons[aria-hidden="true"]')) {
				$(this).prev().attr('data-vk-original-title', $(this).prev().attr('title')).attr('title', $(this).text()).css('background-color', 'pink');
			} else {
				$(this).removeClass(srClass).css('text-transform', 'none');
			}
		});

		$('[aria-label], [aria-labelledby]').each(function () {
			if ($(this).parent().is('.vk-layout') || $(this).is('main, nav, header, form')) {
				return;
			}

			if ($(this).children('.material-icons:not(.mdc-list-item__graphic)').length || $(this).is('.mdc-dialog')) {
				return;
			}

			var labelText = $(this).attr('aria-label');
			if (!labelText && $(this).attr('aria-labelledby')) {
				labelText = '';
				var selector = '#' + $(this).attr('aria-labelledby').replace(/ /g, ' #').split(' ').join(', ');
				$(selector).each(function (index, element) {
					labelText += $(element).text().trim() + ' ';
				});
				labelText = labelText.trim();
			}

			if (!labelText) {
				return;
			}

			if ($(this).hasClass('material-icons') || $(this).is(':input')) {
				$(this).attr('data-vk-original-title', $(this).attr('title')).attr('title', labelText).css('background-color', 'pink');
				$(this).next('.mdc-checkbox__background').css('background-color', 'pink');
			} else {
				if (!$(this).is('input')) {
					$(this).contents().wrapAll('<span data-vk-hidden class="hidden"></span>');
					$('<span style="text-transform: none;">' + labelText + '</span>').appendTo($(this));
				}
				//, [role = "button"]
				if ($(this).is('button:not([role]), .mdc-button')) {
					$(this).css({ width: 'auto', height: 'auto', 'max-height': 'none', 'max-width': 'none' }).attr('data-vk-reset-inline', 'height width max-height max-width');
				}
			}
		});

		if ($('[role="dialog"]').filter(':visible').length === 0) {
			$('.skip-link:not([aria-hidden="true"])').filter(':visible').each(function (index) {
				$(this).addClass('skip-link--visual').css('top', 13 + (index * 45));
			});
		}

		$('button:not([role]), [role="button"]').each(function () {
			var text = 'Button';

			var expanded = $(this).attr('aria-expanded');
			if (expanded) {
				text += expanded === 'false' ? ' Collapsed' : ' Expanded';
			}

			var $targetForRoleLabel = $(this);
			var isExpansionPanelTrigger = $(this).is('.vk-expansion-panel__trigger');
			if (isExpansionPanelTrigger) {
				$targetForRoleLabel = $(this).find('.vk-expansion-panel__trigger__title');

				if ($targetForRoleLabel.length && $targetForRoleLabel.parent().is('.vk-icon-badge-with-text__text')) {
					$targetForRoleLabel = $targetForRoleLabel.parent().next();
				}

				if (!$targetForRoleLabel.length) {
					$targetForRoleLabel = $(this);
				}
			}

			var $icon = $(this).findIncludeSelf('.material-icons');
			if ($icon.length === 1 && !isExpansionPanelTrigger) {
				var title = $icon.attr('title');
				if (!$icon.attr('data-vk-original-title')) {
					$icon.attr('data-vk-original-title', title);
				}

				if (!title) {
					title = $(this).attr('aria-label');
				}

				title = (title ? title + ' - ' : '') + text.toUpperCase();
				$icon.attr('title', title).css('background-color', 'pink');
			} else {
				$targetForRoleLabel.append('<span class="vk-visualize-sr__role-label">' + text + '</span>');
			}
		});

		$('[role="menu"]').each(function () {
			var groupItems = [];

			var resolveGroup = function () {
				for (var i = 0; i < groupItems.length; i++) {
					groupItems[i].append('<span class="vk-visualize-sr__role-label">' + (i + 1) + ' of ' + groupItems.length + '</span>');
				}
			};

			$(this).children().not('[aria-hidden="true"]').each(function () {
				var $item = $(this);
				if ($item.is('[role="menuitem"]')) {
					groupItems.push($item);
				} else {
					resolveGroup();
					groupItems = [];
				}
			});
			resolveGroup();
		});

		//Hacks
		(function () {
			var $careScheduleEditor = $('#careschedule-editor-wrapper').not('.hidden');
			$careScheduleEditor.attr('data-vk-original-style', $careScheduleEditor.attr('style'));
			$careScheduleEditor.css({ width: 400, left: 327, top: 170 });
			$('#careschedule-editor-wrapper-header').css('max-width', 300);
		})();
		$('button p').css('display', 'inline');
		$('.careschedule-common .overview--overview .overview__schedule .schedule-day__times').css('height', 'auto');
	}

	function visualizeScreenReaderOff() {
		$('body').removeClass('vk-visualize-sr');
		$('.vk-visualize-sr__role-label').remove();

		$('.material-icons').css('opacity', '').css('background-color', '');

		$('button.mdc-radio__native-control').css('opacity', '');

		$('[aria-hidden="true"]').each(function () {
			if ($(this).closest('.material-icons').length === 0) {
				$(this).css({ display: '', opacity: '' });
			}
		});

		$('[data-vk-sr-class]').each(function () {
			var srClass = $(this).attr('data-vk-sr-class');
			$(this).removeAttr('data-vk-sr-class');
			if ($(this).prev().is('.material-icons[aria-hidden="true"]')) {
				$(this).prev().attr('title', $(this).prev().attr('data-vk-original-title')).removeAttr('data-vk-original-title').css('background-color', '');
			} else {
				$(this).addClass(srClass).css('text-transform', '');
			}
		});

		$('[data-vk-remove-title="true"]').removeAttr('title');

		$('[aria-label], [aria-labelledby]').each(function () {
			if ($(this).parent().is('.vk-layout')) {
				return;
			}

			if ($(this).children('.material-icons:not(.mdc-list-item__graphic)').length || $(this).is('.mdc-dialog')) {
				return true;
			}

			if ($(this).hasClass('material-icons')) {
				$(this).attr('title', $(this).attr('data-vk-original-title')).removeAttr('data-vk-original-title').css('background-color', '');
			} else {
				$(this).children().last().remove();
				$(this).find('[data-vk-hidden]').contents().unwrap();
			}
		});

		$('.skip-link--visual').each(function () {
			$(this).removeClass('skip-link--visual').css('top', '');
		});

		$('.mdc-checkbox__native-control[style]:not([data-vk-original-title])').each(function () {
			$(this).removeAttr('title');
			$(this).next('.mdc-checkbox__background').removeAttr('style');
		});

		$('[data-vk-original-title]').each(function () {
			$(this).attr('title', $(this).attr('data-vk-original-title'));
			$(this).removeAttr('data-vk-original-title');
			$(this).next('.mdc-checkbox__background').removeAttr('style');
		});

		$('[data-vk-reset-inline]').each(function () {
			var props = $(this).attr('data-vk-reset-inline').split(' ');
			for (var i = 0; i < props.length; i++) {
				$(this).css(props[i], '');
			}
		}).removeAttr('data-vk-reset-inline');

		//Hacks
		(function () {
			var $careScheduleEditor = $('#careschedule-editor-wrapper').not('.hidden');
			$careScheduleEditor.attr('style', $careScheduleEditor.attr('data-vk-original-style')).removeAttr('data-vk-original-style');
			$('#careschedule-editor-wrapper-header').css('max-width', '');
		})();
		$('button p').css('display', '');
		$('.careschedule-common .overview--overview .overview__schedule .schedule-day__times').css('height', '');
	}
</script>

